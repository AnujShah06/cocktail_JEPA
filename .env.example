# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored -- never commit secrets.
#
# Load it before running:  set -a; source .env; set +a

# --- experiment tracking -------------------------------------------------
# Turn W&B on (1) or off (0). Off is correct for Stage 1 plumbing;
# turn on for Stage 3 training.
COCKTAIL_WANDB=0

# Your Weights & Biases API key. Get it from https://wandb.ai/authorize
# Only needed when COCKTAIL_WANDB=1.
WANDB_API_KEY=

# --- cloud paths (Stage 3 only) -----------------------------------------
# On a rented GPU box, point these at the synced corpus and at persistent
# storage. Locally, leave them unset -- config.py defaults to ./corpus
# and ./runs.
# COCKTAIL_DATA_DIR=/workspace/corpus
# COCKTAIL_RUN_DIR=/workspace/runs
